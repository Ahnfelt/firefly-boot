dependency ff:postgresql:0.0.0

import Pg from ff:postgresql


testSql(connection: PgConnection): List[String] {
    connection.statement("""
        select 
            g.benefit,
            g.created
        from guide."Guide" g
        join guide."InquiryHistory" i on i.guideid = g.id
    """).map {row => 
        row.getString("name").grab()
    }
}