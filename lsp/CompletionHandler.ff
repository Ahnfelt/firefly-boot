            type = TConstructor(lspHook.at, "", []), 
            documentation = "// Declares a dependency on the specified version of the package", 
            expectedType = None
        )
        CompletionInfo(
            label = "import", 
            extra = " Module from some:package", 
            more = ""
            snippet = "import ", 
            member = False, 
            type = TConstructor(lspHook.at, "", []), 
            documentation = "// Imports a module from a package", 
            expectedType = None
